# ===========================================================
# Conexiaa .env.example
# -----------------------------------------------------------
# Copy this file to .env and fill in real keys for production.
# The application will work in demo mode without any changes,
# but some features (ElevenLabs, live Zernio) require API keys.
# ===========================================================

# ─── Application ───────────────────────────────────────────
APP_NAME=Conexiaa AI Bridge
APP_VERSION=1.0.0
DEBUG=false

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/conexiaa
# Database pool settings (optional)
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=false

# ─── JWT Authentication ────────────────────────────────────
JWT_SECRET=super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Redis (optional, used for caching / background tasks) ─
REDIS_URL=redis://localhost:6379/0

# ─── Partner Integrations ──────────────────────────────────
# ElevenLabs – Text‑to‑Speech (https://elevenlabs.io)
ELEVENLABS_API_KEY=

# Featherless AI – Model inference (https://featherless.ai)
FEATHERLESS_API_URL=https://api.featherless.ai/v1

# Zernio – Social media aggregation (https://zernio.com)
ZERNIO_CLIENT_ID=
ZERNIO_CLIENT_SECRET=
ZERNIO_REDIRECT_URI=http://localhost:3000/channels/callback

# ─── WebSocket ─────────────────────────────────────────────
WS_PING_INTERVAL_SECONDS=30
WS_PING_TIMEOUT_SECONDS=10

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Docker Compose (optional) ─────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=conexiaa

# ─── Frontend Environment (Next.js) ────────────────────────
# These are prefixed with NEXT_PUBLIC_ to be exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/chat

# ===========================================================
# Testing
# ===========================================================
# 1. Copy this file to .env:  cp .env.example .env
# 2. (Optional) Fill in your ElevenLabs, Featherless, or
#    Zernio keys. The app runs in simulated mode without them.
# 3. Start the backend:   uvicorn backend.main:app --reload
# 4. Start the frontend:  pnpm dev
# 5. Open http://localhost:3000 – chat, AI bridge, and
#    channel management all work with demo data.
# 6. Use docker-compose if you prefer: docker-compose up --build