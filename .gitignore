__pycache__/
*.py[cod]
*.egg-info/
dist/
*.egg

# ─── Environment & Secrets ─────────────────────────────────
.env
.env.local
.env.*.local
*.secret

# API keys / service account files
service-account.json
*.pem

# ─── Build / Cache ─────────────────────────────────────────
